PORT=5101
MICROSIP_CONNECTOR_API_KEY=replace_with_secure_key
MICROSIP_CONNECTOR_REQUIRE_API_KEY=true
MICROSIP_DATA_MODE=mock

# Modo "dll" (adaptador real con ApiMicrosip.dll)
MICROSIP_ADAPTER_SHELL=powershell
MICROSIP_ADAPTER_SCRIPT_PATH=./adapters/powershell/MicrosipApiAdapter.ps1
MICROSIP_ADAPTER_TIMEOUT_MS=60000
MICROSIP_DLL_PATH=D:\Usuarios\Programador\Documentos\ApiMicrosip2025\ApiMicrosip.dll
MICROSIP_DATABASE_NAME=LINHER
MICROSIP_DATABASE_USER=SYSDBA
MICROSIP_DATABASE_PASSWORD=masterkey

# Queries SQL para cada export. Ajustar nombres de tabla/campos segun tu instalacion Microsip.
MICROSIP_SQL_DEPARTMENTS=SELECT DEPTO_NO_ID, NOMBRE, ES_PREDET FROM DEPTOS_NO
MICROSIP_SQL_JOB_TITLES=SELECT PUESTO_NO_ID, NOMBRE, ES_PREDET FROM PUESTOS_NO
MICROSIP_SQL_EMPLOYEES=SELECT EMPLEADO_ID, NUMERO, NOMBRES, APELLIDO_PATERNO, DEPTO_NO_ID, PUESTO_NO_ID, ESTATUS, FECHA_INGRESO FROM EMPLEADOS

# Mapeo de campos: destino:columna_origen
MICROSIP_FIELDS_DEPARTMENTS=microsip_department_id:DEPTO_NO_ID,name:NOMBRE,is_active:ES_PREDET
MICROSIP_FIELDS_JOB_TITLES=microsip_job_title_id:PUESTO_NO_ID,name:NOMBRE,is_active:ES_PREDET
MICROSIP_FIELDS_EMPLOYEES=microsip_employee_id:EMPLEADO_ID,employee_number:NUMERO,first_name:NOMBRES,last_name:APELLIDO_PATERNO,department_id:DEPTO_NO_ID,job_title_id:PUESTO_NO_ID,employment_status:ESTATUS,hired_at:FECHA_INGRESO,terminated_at:FECHA_BAJA
