PORT=5101
MICROSIP_CONNECTOR_API_KEY=replace_with_secure_key
MICROSIP_CONNECTOR_REQUIRE_API_KEY=true
MICROSIP_DATA_MODE=dll

# Modo "dll" (adaptador real con ApiMicrosip.dll)
MICROSIP_ADAPTER_SHELL=C:\Windows\SysWOW64\WindowsPowerShell\v1.0\powershell.exe
MICROSIP_ADAPTER_SCRIPT_PATH=./adapters/powershell/MicrosipApiAdapter.ps1
MICROSIP_ADAPTER_TIMEOUT_MS=60000
MICROSIP_DLL_PATH=C:\ApiMicrosip2025\ApiMicrosip.dll
MICROSIP_DATABASE_NAME=C:\Microsip datos\LINHER.FDB
MICROSIP_DATABASE_USER=SYSDBA
MICROSIP_DATABASE_PASSWORD=masterkey

# Queries SQL para cada export. Ajustar nombres de tabla/campos segun tu instalacion Microsip.
MICROSIP_SQL_DEPARTMENTS=SELECT CAST(DEPTO_NO_ID AS VARCHAR(20)) AS microsip_department_id, TRIM(NOMBRE) AS name, '1' AS is_active FROM DEPTOS_NO
MICROSIP_SQL_JOB_TITLES=SELECT CAST(PUESTO_NO_ID AS VARCHAR(20)) AS microsip_job_title_id, TRIM(NOMBRE) AS name, '1' AS is_active FROM PUESTOS_NO
MICROSIP_SQL_EMPLOYEES=SELECT CAST(e.EMPLEADO_ID AS VARCHAR(20)) AS microsip_employee_id, CAST(e.NUMERO AS VARCHAR(20)) AS employee_number, TRIM(COALESCE(e.NOMBRES, '')) AS first_name, TRIM(COALESCE(e.APELLIDO_PATERNO, '') || ' ' || COALESCE(e.APELLIDO_MATERNO, '')) AS last_name, TRIM(COALESCE(e.NOMBRE_COMPLETO, '')) AS full_name, CAST(e.DEPTO_NO_ID AS VARCHAR(20)) AS department_id, CAST(e.PUESTO_NO_ID AS VARCHAR(20)) AS job_title_id, CASE WHEN COALESCE(e.ESTATUS, 'A') IN ('A','ACTIVO','1') THEN 'active' ELSE 'inactive' END AS employment_status, CAST(e.FECHA_INGRESO AS VARCHAR(10)) AS hired_at, CAST(NULL AS VARCHAR(10)) AS terminated_at, CAST(e.JEFE_INMEDIATO_ID AS VARCHAR(20)) AS manager_microsip_employee_id, TRIM(COALESCE(m.NOMBRE_COMPLETO, '')) AS manager_name, TRIM(COALESCE(e.CONTRATO_SAT, COALESCE(e.CONTRATO, ''))) AS contract_type, TRIM(COALESCE(e.FORMA_PAGO, '')) AS payment_method, TRIM(COALESCE(e.TURNO, '')) AS shift_code, TRIM(COALESCE(e.TURNO, '')) AS shift_name, TRIM(COALESCE(e.HORARIO, '')) AS schedule, CAST(COALESCE(e.DIAS_HRS_JSR, e.JORNADA, 0) AS VARCHAR(20)) AS workday_hours, TRIM(COALESCE(e.REGIMEN_FISCAL, '')) AS payroll_regime_code, TRIM(COALESCE(e.CONTRATO_SAT, '')) AS sat_contract_code, TRIM(COALESCE(e.JORNADA_SAT, '')) AS sat_workday_code, TRIM(COALESCE(e.INGRESO_SAT, '')) AS sat_entry_code, CASE WHEN COALESCE(e.ES_SINDICALIZADO, 'N') = 'S' THEN '1' ELSE '0' END AS is_unionized, CAST(e.TABLA_ANTIG_ID AS VARCHAR(20)) AS antiquity_table_code, CAST(e.SALARIO_DIARIO AS VARCHAR(30)) AS salary_daily, CAST(e.SALARIO_INTEG AS VARCHAR(30)) AS salary_integrated_daily, 'MXN' AS salary_currency, TRIM(COALESCE(e.TIPO_SALARIO, '')) AS salary_type, TRIM(COALESCE(e.REGIMEN_FISCAL, '')) AS payroll_regime, CAST(e.SALARIO_INTEG AS VARCHAR(30)) AS contribution_base_amount, TRIM(COALESCE(e.REG_IMSS, '')) AS social_security_number, CAST(e.UNIDAD_MEDICA AS VARCHAR(30)) AS imss_clinic_code, CAST(NULL AS VARCHAR(30)) AS employee_contribution_amount, CAST(NULL AS VARCHAR(30)) AS employer_contribution_amount, CAST(NULL AS VARCHAR(30)) AS total_contribution_amount, TRIM(COALESCE(e.SEXO, '')) AS sex_code, CAST(e.FECHA_NACIMIENTO AS VARCHAR(10)) AS birth_date, CAST(e.CIUDAD_NACIMIENTO_ID AS VARCHAR(20)) AS birth_city_id, TRIM(COALESCE(e.ESTADO_CIVIL, '')) AS marital_status_code, CAST(COALESCE(e.NUM_HIJOS, 0) AS VARCHAR(20)) AS children_count, TRIM(COALESCE(e.RFC, '')) AS rfc, TRIM(COALESCE(e.CURP, '')) AS curp, TRIM(COALESCE(e.OTRO_REG, '')) AS other_registry, TRIM(COALESCE(e.REG_IMSS, '')) AS social_security_registry, TRIM(COALESCE(e.EMAIL, '')) AS email, TRIM(COALESCE(e.TELEFONO1, '')) AS phone_primary, TRIM(COALESCE(e.TELEFONO2, '')) AS phone_secondary, TRIM(COALESCE(e.CALLE, '')) AS full_address, TRIM(COALESCE(e.NOMBRE_CALLE, '')) AS street_name, TRIM(COALESCE(e.NUM_EXTERIOR, '')) AS exterior_number, TRIM(COALESCE(e.NUM_INTERIOR, '')) AS interior_number, TRIM(COALESCE(e.COLONIA, '')) AS neighborhood, TRIM(COALESCE(e.POBLACION, '')) AS locality, TRIM(COALESCE(e.REFERENCIA, '')) AS reference_note, CAST(e.CIUDAD_ID AS VARCHAR(20)) AS city_id, TRIM(COALESCE(e.CODIGO_POSTAL, '')) AS postal_code, TRIM(COALESCE(e.NOMBRE_PADRE, '')) AS father_name, TRIM(COALESCE(e.NOMBRE_MADRE, '')) AS mother_name, CAST(e.GRUPO_PAGO_ELECT_ID AS VARCHAR(20)) AS payment_group_code, CAST(e.TIPO_CTABAN_PAGO_ELECT AS VARCHAR(20)) AS payment_account_type, TRIM(COALESCE(e.NUM_CTABAN_PAGO_ELECT, '')) AS payment_account_number FROM EMPLEADOS e LEFT JOIN EMPLEADOS m ON m.EMPLEADO_ID = e.JEFE_INMEDIATO_ID
MICROSIP_SQL_COUNTRIES=SELECT CAST(PAIS_ID AS VARCHAR(20)) AS microsip_country_id, TRIM(NOMBRE) AS name, TRIM(NOMBRE_ABREV) AS abbrev, TRIM(CLAVE_FISCAL) AS fiscal_key, CASE WHEN COALESCE(ES_PREDET, 'N') = 'S' THEN '1' ELSE '0' END AS is_default, '1' AS is_active FROM PAISES
MICROSIP_SQL_STATES=SELECT CAST(ESTADO_ID AS VARCHAR(20)) AS microsip_state_id, CAST(PAIS_ID AS VARCHAR(20)) AS microsip_country_id, TRIM(NOMBRE) AS name, TRIM(NOMBRE_ABREV) AS abbrev, TRIM(CLAVE_FISCAL) AS fiscal_key, CASE WHEN COALESCE(ES_PREDET, 'N') = 'S' THEN '1' ELSE '0' END AS is_default, '1' AS is_active FROM ESTADOS
MICROSIP_SQL_CITIES=SELECT CAST(CIUDAD_ID AS VARCHAR(20)) AS microsip_city_id, CAST(ESTADO_ID AS VARCHAR(20)) AS microsip_state_id, TRIM(NOMBRE) AS name, TRIM(CLAVE_FISCAL) AS fiscal_key, CASE WHEN COALESCE(ES_PREDET, 'N') = 'S' THEN '1' ELSE '0' END AS is_default, '1' AS is_active FROM CIUDADES
MICROSIP_SQL_PAYROLL_PAYMENTS=SELECT CAST(PAGO_NOMINA_ID AS VARCHAR(20)) AS microsip_payroll_payment_id, CAST(NOMINA_ID AS VARCHAR(20)) AS payroll_batch_id, CAST(EMPLEADO_ID AS VARCHAR(20)) AS microsip_employee_id, CAST(FECHA AS VARCHAR(10)) AS payment_date, TRIM(TIPO_NOM) AS payroll_type, TRIM(FORMA_PAGO) AS payment_method, TRIM(TIPO_PAGO) AS payment_type, TRIM(TIPO_SALARIO) AS salary_type, CAST(SALARIO_INTEG AS VARCHAR(30)) AS integrated_salary, CAST(DIAS_TRAB AS VARCHAR(30)) AS work_days, CAST(HORAS_TRAB AS VARCHAR(30)) AS work_hours, CAST(DIAS_VAC AS VARCHAR(30)) AS vacation_days, CAST(DIAS_COT AS VARCHAR(30)) AS cotization_days, CAST(FALTAS_DEC AS VARCHAR(30)) AS absences_days, CAST(DIAS_INCAP AS VARCHAR(30)) AS incapacity_days, CAST(HORAS_EXT_DEC AS VARCHAR(30)) AS overtime_hours, CAST(HORAS_EXT_EXCED AS VARCHAR(30)) AS overtime_excess_hours, CAST(IMPORTE_HORAS_EXT_EXCED AS VARCHAR(30)) AS overtime_excess_amount, CAST(SBC_SMDF AS VARCHAR(30)) AS base_contribution_salary, CAST(TOTAL_PERCEP AS VARCHAR(30)) AS total_earnings, CAST(TOTAL_RETEN AS VARCHAR(30)) AS total_deductions, CAST(TOTAL_OTROS_PAGOS AS VARCHAR(30)) AS total_other_payments, CAST(TOTAL_PERCEP_GRAV AS VARCHAR(30)) AS total_earnings_taxable, CAST(TOTAL_PERCEP_EXEN AS VARCHAR(30)) AS total_earnings_exempt, CAST(BASE_IMPTO_ESTATAL AS VARCHAR(30)) AS state_tax_base, CAST(BASE_PTU AS VARCHAR(30)) AS ptu_base, CAST((TOTAL_PERCEP - TOTAL_RETEN) AS VARCHAR(30)) AS net_amount, CASE WHEN COALESCE(APLICADO, 'N') = 'S' THEN '1' ELSE '0' END AS is_applied, CASE WHEN COALESCE(ENVIADO, 'N') = 'S' THEN '1' ELSE '0' END AS is_sent, TRIM(EMAIL_ENVIO) AS sent_email FROM PAGOS_NOMINA

# Campos permitidos por dataset (ya normalizados por alias SQL)
MICROSIP_FIELDS_DEPARTMENTS=microsip_department_id,name,is_active
MICROSIP_FIELDS_JOB_TITLES=microsip_job_title_id,name,is_active
MICROSIP_FIELDS_EMPLOYEES=microsip_employee_id,employee_number,first_name,last_name,full_name,department_id,job_title_id,employment_status,hired_at,terminated_at,manager_microsip_employee_id,manager_name,contract_type,payment_method,shift_code,shift_name,schedule,workday_hours,payroll_regime_code,sat_contract_code,sat_workday_code,sat_entry_code,is_unionized,antiquity_table_code,salary_daily,salary_integrated_daily,salary_currency,salary_type,payroll_regime,contribution_base_amount,social_security_number,imss_clinic_code,employee_contribution_amount,employer_contribution_amount,total_contribution_amount,sex_code,birth_date,birth_city_id,marital_status_code,children_count,rfc,curp,other_registry,social_security_registry,email,phone_primary,phone_secondary,full_address,street_name,exterior_number,interior_number,neighborhood,locality,reference_note,city_id,postal_code,father_name,mother_name,payment_group_code,payment_account_type,payment_account_number
MICROSIP_FIELDS_COUNTRIES=microsip_country_id,name,abbrev,fiscal_key,is_default,is_active
MICROSIP_FIELDS_STATES=microsip_state_id,microsip_country_id,name,abbrev,fiscal_key,is_default,is_active
MICROSIP_FIELDS_CITIES=microsip_city_id,microsip_state_id,name,fiscal_key,is_default,is_active
MICROSIP_FIELDS_PAYROLL_PAYMENTS=microsip_payroll_payment_id,payroll_batch_id,microsip_employee_id,payment_date,payroll_type,payment_method,payment_type,salary_type,integrated_salary,work_days,work_hours,vacation_days,cotization_days,absences_days,incapacity_days,overtime_hours,overtime_excess_hours,overtime_excess_amount,base_contribution_salary,total_earnings,total_deductions,total_other_payments,total_earnings_taxable,total_earnings_exempt,state_tax_base,ptu_base,net_amount,is_applied,is_sent,sent_email
